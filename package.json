{
  "name": "webtoon-panel-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "bin": {
    "webtoon-panel-studio": "./build/bin/wps.js",
    "wps": "./build/bin/wps.js"
  },
  "scripts": {
    "dev:ui": "vite --config vite-config.ts --host 127.0.0.1",
    "dev:server": "tsx watch server/server.ts",
    "dev": "concurrently -n ui,server -c cyan,magenta \"pnpm dev:ui\" \"pnpm dev:server\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig-server.json",
    "build:ui": "vite build --config vite-config.ts",
    "build:server": "tsc -p tsconfig-server.json",
    "build": "pnpm build:ui && pnpm build:server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node build/server/server.js",
    "wps": "tsx bin/wps.ts",
    "preview": "vite preview --config vite-config.ts --host 127.0.0.1"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "lucide-react": "^1.14.0",
    "openai": "^5.8.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
