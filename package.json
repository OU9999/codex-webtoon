{
  "name": "webtoon-panel-studio",
  "version": "0.1.0",
  "description": "Local-first webtoon panel editor with AI image generation. Runs from npx, authenticates via OpenAI API key or Codex OAuth.",
  "keywords": [
    "webtoon",
    "comic",
    "panel",
    "openai",
    "image-generation",
    "local-first",
    "codex",
    "oauth"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "bin": {
    "webtoon-panel-studio": "./build/bin/wps.js",
    "wps": "./build/bin/wps.js"
  },
  "files": [
    "build",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev:ui": "vite --config vite-config.ts --host 127.0.0.1",
    "dev:server": "tsx watch server/server.ts",
    "dev": "concurrently -n ui,server -c cyan,magenta \"pnpm dev:ui\" \"pnpm dev:server\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig-server.json",
    "build:ui": "vite build --config vite-config.ts",
    "build:server": "tsc -p tsconfig-server.json && chmod +x build/bin/wps.js",
    "build": "pnpm build:ui && pnpm build:server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test tests/*.test.ts",
    "start": "node build/server/server.js",
    "wps": "tsx bin/wps.ts",
    "preview": "vite preview --config vite-config.ts --host 127.0.0.1",
    "prepublishOnly": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "express": "^5.1.0",
    "i18next": "^26.2.0",
    "openai": "^5.8.2",
    "react-i18next": "^17.0.8",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "lucide-react": "^1.14.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
